# Clarvia AEO Scanner — Environment Variables
# Copy to .env and fill in your values

# --- Server ---
SCANNER_HOST=0.0.0.0
SCANNER_PORT=8000
SCANNER_CORS_ORIGINS=["http://localhost:3000","https://scanner.clarvia.io"]

# --- Frontend URL (for Stripe checkout redirects) ---
SCANNER_FRONTEND_URL=http://localhost:3000

# --- Stripe (optional — payment features disabled without these) ---
SCANNER_STRIPE_SECRET_KEY=sk_test_...
SCANNER_STRIPE_WEBHOOK_SECRET=whsec_...
SCANNER_STRIPE_PRICE_ID=

# --- Supabase (optional — in-memory storage used without these) ---
SCANNER_SUPABASE_URL=https://your-project.supabase.co
SCANNER_SUPABASE_ANON_KEY=eyJ...

# --- HTTP Probing ---
SCANNER_HTTP_TIMEOUT=10.0
SCANNER_LATENCY_SAMPLES=5
SCANNER_LATENCY_DELAY=0.2

# --- Cache ---
SCANNER_CACHE_TTL_SECONDS=86400
