{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.digitamaz/clarvia",
  "description": "AI agent tool discovery and scoring. Search 15,400+ MCP servers, APIs, and CLIs.",
  "repository": {
    "url": "https://github.com/clarvia-project/scanner.git",
    "source": "github"
  },
  "version": "1.1.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "clarvia-mcp-server",
      "version": "1.1.2",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "remoteEndpoints": [
    {
      "url": "https://clarvia-api.onrender.com/mcp/",
      "transport": {
        "type": "streamable-http"
      }
    }
  ]
}
