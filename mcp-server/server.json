{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.clarvia-project/scanner",
  "description": "Clarvia MCP Server - Search and evaluate AI services via Model Context Protocol. Provides tools for scanning, benchmarking, and discovering AI agents and services.",
  "repository": {
    "url": "https://github.com/clarvia-project/scanner",
    "source": "github"
  },
  "version": "1.1.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "clarvia-mcp-server",
      "version": "1.0.1",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "remoteEndpoints": [
    {
      "url": "https://clarvia-api.onrender.com/mcp/",
      "transport": {
        "type": "streamable-http"
      }
    }
  ]
}
