{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.digitamaz/clarvia",
  "description": "Search, scan, and benchmark AI services for agent-discoverability (AEO scoring)",
  "repository": {
    "url": "https://github.com/clarvia-project/scanner",
    "source": "github"
  },
  "version": "1.1.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "clarvia-mcp-server",
      "version": "1.0.2",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "remoteEndpoints": [
    {
      "url": "https://clarvia-api.onrender.com/mcp/",
      "transport": {
        "type": "streamable-http"
      }
    }
  ]
}
