{
  "schema_version": "1.0",
  "name": "Clarvia",
  "description": "AI agent tool discovery and AEO scoring platform. Search, evaluate, and gate-check 15,400+ AI agent tools (MCP servers, APIs, CLIs, Skills) scored for agent readiness.",
  "url": "https://clarvia.art",
  "logo": "https://clarvia.art/logos/clarvia-logo.png",
  "api": {
    "type": "rest",
    "base_url": "https://clarvia-api.onrender.com",
    "openapi": "https://clarvia-api.onrender.com/openapi.json",
    "docs": "https://clarvia-api.onrender.com/docs",
    "authentication": {
      "type": "api_key",
      "header": "X-API-Key",
      "required": false,
      "note": "Most read endpoints are public. API key increases rate limits."
    }
  },
  "mcp": {
    "npm_package": "clarvia-mcp-server",
    "install": "npx -y clarvia-mcp-server",
    "remote_endpoint": "https://clarvia-api.onrender.com/mcp/",
    "tools_count": 16,
    "python_tools_count": 24,
    "transport": ["stdio", "streamable-http"],
    "registry_id": "io.github.digitamaz/clarvia"
  },
  "capabilities": [
    "tool_discovery",
    "tool_scoring",
    "agent_gate_check",
    "batch_tool_check",
    "find_alternatives",
    "live_probe",
    "dependency_audit",
    "tool_comparison",
    "trend_analysis",
    "intent_recommendation",
    "feedback_submission",
    "category_browsing",
    "leaderboard",
    "vulnerability_check",
    "compliance_checklist"
  ],
  "use_cases": [
    "Before calling any external API, verify it is agent-ready",
    "Search for the best tool in a category by AEO score",
    "Find alternatives when a tool fails quality checks",
    "Audit your agent's dependency stack for security issues",
    "Track trending tools in the AI agent ecosystem"
  ],
  "pricing": {
    "model": "freemium",
    "free_tier": "10 scans/hour, unlimited search",
    "pro_tier": "100 scans/hour with API key"
  },
  "rate_limits": {
    "free": { "scans_per_hour": 10, "search_per_minute": 100 },
    "pro": { "scans_per_hour": 100, "search_per_minute": 1000 }
  },
  "discovery": {
    "llms_txt": "https://clarvia.art/llms.txt",
    "llms_full_txt": "https://clarvia.art/llms-full.txt",
    "sitemap": "https://clarvia.art/sitemap.xml",
    "robots_txt": "https://clarvia.art/robots.txt",
    "github": "https://github.com/clarvia-project/scanner"
  }
}
